{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "VIVLA Docs",
  "colors": {
    "primary": "#0c2425",
    "light": "#cf7625",
    "dark": "#0c2425"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "family": "Sneak",
    "weight": 400,
    "heading": {
      "family": "Teodor",
      "weight": 400,
      "source": "/fonts/Teodor-Regular.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Sneak",
      "weight": 400,
      "source": "/fonts/Sneak-Regular.woff2",
      "format": "woff2"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "architecture",
              "environments",
              "repositories"
            ]
          }
        ]
      },
      {
        "tab": "Vivla Tools",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "tools/index"
            ]
          }
        ]
      },
      {
        "tab": "Mobile App",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "mobile/index"
            ]
          }
        ]
      },
      {
        "tab": "Vivla API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "backend/index"
            ]
          }
        ]
      },
      {
        "tab": "Panel",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "panel/index"
            ]
          }
        ]
      },
      {
        "tab": "Infra",
        "groups": [
          {
            "group": "Infrastructure",
            "pages": [
              "infra/index",
              "infra/railway",
              "infra/cloudflare",
              "infra/slack-notifications"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/vivla-tech",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "VIVLA",
        "href": "https://vivla.com"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/vivla-tech"
    }
  }
}
