{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "VIVLA Docs",
  "colors": {
    "primary": "#6D28D9",
    "light": "#8B5CF6",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "architecture",
              "environments"
            ]
          }
        ]
      },
      {
        "tab": "API Principal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "backend/index",
              "backend/getting-started"
            ]
          },
          {
            "group": "API reference",
            "pages": [
              "backend/api/authentication",
              "backend/api/properties",
              "backend/api/bookings"
            ]
          },
          {
            "group": "Database",
            "pages": [
              "backend/database/schema",
              "backend/database/migrations"
            ]
          }
        ]
      },
      {
        "tab": "Mobile",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "mobile/index",
              "mobile/getting-started"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "mobile/architecture/navigation",
              "mobile/architecture/state-management"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "mobile/guides/builds",
              "mobile/guides/deployment"
            ]
          }
        ]
      },
      {
        "tab": "Tools",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "tools/index"
            ]
          },
          {
            "group": "Chat de soporte",
            "pages": [
              "tools/chat/index",
              "tools/chat/frontend",
              "tools/chat/mobile-integration"
            ]
          },
          {
            "group": "Community guidelines",
            "pages": [
              "tools/community/index",
              "tools/community/portal"
            ]
          },
          {
            "group": "Guías de mantenimiento",
            "pages": [
              "tools/maintenance/index"
            ]
          },
          {
            "group": "Tools API",
            "pages": [
              "tools/api/index",
              "tools/api/endpoints",
              "tools/api/database"
            ]
          }
        ]
      },
      {
        "tab": "Infra",
        "groups": [
          {
            "group": "Infrastructure",
            "pages": [
              "infra/index",
              "infra/railway",
              "infra/cloudflare"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/vivla-tech",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "VIVLA",
        "href": "https://vivla.com"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/vivla-tech"
    }
  }
}
