{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "VIVLA Docs",
  "colors": {
    "primary": "#6D28D9",
    "light": "#8B5CF6",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "architecture",
              "environments"
            ]
          }
        ]
      },
      {
        "tab": "Infra",
        "groups": [
          {
            "group": "Infrastructure",
            "pages": [
              "infra/index",
              "infra/railway",
              "infra/cloudflare"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/vivla-tech",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "VIVLA",
        "href": "https://vivla.com"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/vivla-tech"
    }
  }
}
